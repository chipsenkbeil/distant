/target
**/.DS_Store
/distant-core/Cargo.lock
/distant-ssh2/Cargo.lock
**/*.un~

# Ignore contents of .claude by default (use /* not / so negations work)
.claude/*

# Explicitly allowlist project-related settings
!.claude/CLAUDE.md
!.claude/.clauderules
!.claude/agents/
!.claude/prompts/
!.claude/skills/
!.claude/mcp.json
!.claude/settings.json
